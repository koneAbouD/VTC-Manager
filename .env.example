# ==========================================================================
# Variables d'environnement — PRODUCTION (VPS)
# Copier en `.env` et renseigner les vraies valeurs : cp .env.example .env
# NE PAS committer le fichier .env (secrets).
# ==========================================================================

# Version de l'image et port exposé sur le VPS
APP_VERSION=latest
APP_PORT=8081

# Nom du réseau Docker de l'infra existante (cf. `docker network ls`)
INFRA_NETWORK=infra

# --- Base de données PostgreSQL (existante) ---
# DB_HOST = nom du conteneur/service Postgres sur le réseau infra
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vtc_manager
DB_USERNAME=vtc_user
DB_PASSWORD=change-me

# --- Keycloak (existant) ---
# Utiliser le nom de service interne (réseau Docker), ex: http://keycloak:8080
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/vtc-manager
KEYCLOAK_JWK_URI=http://keycloak:8080/realms/vtc-manager/protocol/openid-connect/certs
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=vtc-manager
KEYCLOAK_CLIENT_ID=vtc-manager-backend
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_ADMIN_CLIENT_ID=vtc-manager-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me

# --- MinIO (existant) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=vtc-documents
